# Normalize line endings to LF in the repository
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
*.jar binary
